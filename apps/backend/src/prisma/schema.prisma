generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  ADMIN
}

enum TaskStatus {
  IN_PROGRESS
  HOLD
  COMPLETED
}

// ==========================================
// 1. USER MODEL
// ==========================================
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String?
  password  String
  role      Role     @default(USER)

  fcmToken String?

  departments Department[]
  assignedTasks Task[]     @relation("TaskAssignee")
  receivedNotifications NotificationStatus[]
  
  createdAt DateTime @default(now())
}

// ==========================================
// 2. DEPARTMENT MODEL
// ==========================================
model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  
  users     User[]
  tasks     Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 3. TASK MODEL
// ==========================================
model Task {
  id          String     @id @default(cuid())
  name        String     
  description String?    @db.Text
  status      TaskStatus @default(IN_PROGRESS)

// New Flexible Numerical Metric Fields
  metricValue  Float?     // Stores the raw number (supports decimals like 450.75)
  metricLabel  String?    // Describes what the number means (e.g., "Books Sold")
    
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  assigneeId   String?
  assignee     User?     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeName String?   

  remarks     Remark[]
  deadline    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ==========================================
// 4. REMARK MODEL
// ==========================================
model Remark {
  id        String   @id @default(cuid())
  text      String   @db.Text
  
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorName String   

  createdAt DateTime @default(now())
}

model Notification {
  id           String    @id @default(cuid())
  title        String
  body         String
  senderId     String?   // The user who triggered it (null if system auto-generated)
  senderName   String    // Stored directly to avoid heavy join queries later
  
  // Targeting
  targetDeptId String?   // If null, it means broadcasted globally to "ALL ADMINS"
  isAdminOnly  Boolean   @default(false) 

  createdAt    DateTime  @default(now())
  
  // Relations
  statuses     NotificationStatus[]
}

model NotificationStatus {
  id             String       @id @default(cuid())
  notificationId String
  userId         String
  isRead         Boolean      @default(false)
  readAt         DateTime?

  // Relations
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId]) // Prevents duplicate delivery states
}